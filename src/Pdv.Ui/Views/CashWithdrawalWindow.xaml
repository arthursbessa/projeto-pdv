<Window x:Class="Pdv.Ui.Views.CashWithdrawalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sangria de caixa" Height="320" Width="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#0F172A">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Sangria" Foreground="White" FontWeight="Bold" FontSize="24" Margin="0,0,0,12"/>
            <TextBlock Text="Valor" Foreground="#CBD5E1"/>
            <TextBox x:Name="AmountTextBox" Text="0,00" Height="34" FontSize="16" Margin="0,6,0,12"/>
            <TextBlock Text="Motivo (opcional)" Foreground="#CBD5E1"/>
            <TextBox x:Name="ReasonTextBox" Height="70" Margin="0,6,0,14" TextWrapping="Wrap" AcceptsReturn="True"/>
            <Button Content="Registrar sangria" Height="40" Background="#F59E0B" Foreground="White" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
