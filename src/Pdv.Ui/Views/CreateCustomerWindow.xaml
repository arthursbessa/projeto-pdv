<Window x:Class="Pdv.Ui.Views.CreateCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Cadastrar cliente"
        Height="560"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cadastrar cliente" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="White" CornerRadius="14" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Nome" FontWeight="SemiBold"/>
                <TextBox Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,12" Height="38" Padding="10,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="2" Text="CPF" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="Telefone" FontWeight="SemiBold"/>
                <TextBox Grid.Row="3" Margin="0,8,12,12" Height="38" Padding="10,0" Text="{Binding Cpf, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="0,8,0,12" Height="38" Padding="10,0" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Text="E-mail" FontWeight="SemiBold"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="Endereco" FontWeight="SemiBold"/>
                <TextBox Grid.Row="5" Margin="0,8,12,12" Height="38" Padding="10,0" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="0,8,0,12" Height="38" Padding="10,0" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Text="Observacoes" FontWeight="SemiBold"/>
                <TextBox Grid.Row="7" Grid.ColumnSpan="2" Margin="0,8,0,0" Height="84" Padding="10,8" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <ProgressBar Height="6" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,10" Foreground="{Binding StatusBrush}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Click="Cancel_Click" Padding="14,8" Margin="0,0,8,0" Background="#64748B" BorderBrush="#64748B" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="Salvar cliente" Click="Save_Click" Padding="16,8" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
