<Window x:Class="Pdv.Ui.Views.CreateCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Cliente"
        Height="620"
        Width="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding WindowTitle}" FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" Foreground="{Binding StatusBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="White" CornerRadius="18" BorderBrush="#DBEAFE" BorderThickness="1" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
                        <TextBlock Text="Dados do cliente" FontSize="16" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Mantenha o cadastro padronizado para uso no fechamento de venda." Foreground="#64748B" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,14">
                        <TextBlock Text="Nome *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,0,12,14">
                        <TextBlock Text="CPF" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Cpf, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="12,0,0,14">
                        <TextBlock Text="Telefone" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,14">
                        <TextBlock Text="E-mail" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2">
                        <TextBlock Text="Endereço" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Observações" FontWeight="SemiBold" Margin="0,14,0,8"/>
                        <TextBox Height="96" Padding="12,8" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <ProgressBar Height="6" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Excluir"
                        Margin="0,0,8,0"
                        Padding="16,10"
                        Background="#DC2626"
                        BorderBrush="#DC2626"
                        Foreground="White"
                        Visibility="{Binding ShowDeleteButton, Converter={StaticResource BoolToVisibility}}"
                        Click="Delete_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="Cancelar"
                        Margin="0,0,8,0"
                        Padding="16,10"
                        Background="#64748B"
                        BorderBrush="#64748B"
                        Foreground="White"
                        Click="Cancel_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="{Binding SaveButtonText}"
                        Padding="16,10"
                        Background="#2563EB"
                        BorderBrush="#2563EB"
                        Foreground="White"
                        Click="Save_Click"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
