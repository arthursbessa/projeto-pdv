<Window x:Class="Pdv.Ui.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cadastro de Usuários" Height="620" Width="900" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Width="250" Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Buscar" Margin="8,0" Padding="12,6" Command="{Binding SearchCommand}"/>
            <Button Content="Novo" Padding="12,6" Command="{Binding NewCommand}"/>
            <Button Content="Salvar" Margin="8,0" Padding="12,6" Command="{Binding SaveCommand}"/>
            <Button Content="Ativar/Desativar" Padding="12,6" Command="{Binding ToggleCommand}"/>
        </StackPanel>
        <DataGrid Grid.Row="1" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Usuário" Binding="{Binding Username}" Width="180"/>
                <DataGridTextColumn Header="Nome" Binding="{Binding FullName}" Width="*"/>
                <DataGridTextColumn Header="Senha (nova)" Binding="{Binding Password}" Width="160"/>
                <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding Active}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Margin="0,10,0,0" FontWeight="SemiBold"/>
    </Grid>
</Window>
