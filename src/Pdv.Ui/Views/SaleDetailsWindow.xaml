<Window x:Class="Pdv.Ui.Views.SaleDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Detalhes da venda"
        Height="760"
        Width="960"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Detalhes da venda" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding SelectedSaleIdentifier, StringFormat=Venda: {0}}" Margin="0,6,0,0" Foreground="#64748B"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#EFF6FF" CornerRadius="12" Padding="12" Margin="0,0,10,10">
                        <StackPanel>
                            <TextBlock Text="Id venda" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleIdentifier}" FontWeight="Bold" Foreground="#0F172A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#EFF6FF" CornerRadius="12" Padding="12" Margin="10,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Status" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleStatus}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,0,10,10">
                        <StackPanel>
                            <TextBlock Text="Cliente" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleCustomer}" FontWeight="Bold" Foreground="#0F172A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="10,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Caixa" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleCashier}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,0,10,10">
                        <StackPanel>
                            <TextBlock Text="Data" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleDate}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="10,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Pagamento" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSalePayment}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#E0F2FE" CornerRadius="12" Padding="12" Margin="0,0,10,10">
                        <StackPanel>
                            <TextBlock Text="Total" FontSize="12" Foreground="#0369A1" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleTotal}" FontWeight="Bold" FontSize="22" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#DBEAFE" CornerRadius="12" Padding="12" Margin="10,0,10,10">
                        <StackPanel>
                            <TextBlock Text="Desconto" FontSize="12" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleDiscount}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#ECFCCB" CornerRadius="12" Padding="12" Margin="10,0,10,10">
                        <StackPanel>
                            <TextBlock Text="Recebido" FontSize="12" Foreground="#4D7C0F" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleReceived}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="#FEF3C7" CornerRadius="12" Padding="12" Margin="10,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Troco" FontSize="12" Foreground="#B45309" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleChange}" FontWeight="Bold" Foreground="#0F172A"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#F8FAFC" CornerRadius="12" Padding="12" Margin="0,0,10,10">
                        <StackPanel>
                            <TextBlock Text="CPF/CNPJ no comprovante" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedSaleReceiptTaxId}" FontWeight="Bold" Foreground="#0F172A" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock Text="Itens da venda" FontSize="16" FontWeight="Bold" Margin="0,10,0,8" Foreground="#0F172A"/>
                <DataGrid ItemsSource="{Binding SaleItems}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          BorderBrush="#CBD5E1"
                          BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Produto" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Codigo" Binding="{Binding Barcode}" Width="130"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="60"/>
                        <DataGridTextColumn Header="Devolvida" Binding="{Binding RefundedQuantity}" Width="80"/>
                        <DataGridTextColumn Header="Disponivel" Binding="{Binding RemainingQuantity}" Width="80"/>
                        <DataGridTextColumn Header="Preco" Binding="{Binding PriceFormatted}" Width="90"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding SubtotalFormatted}" Width="100"/>
                        <DataGridTemplateColumn Header="Devolver agora" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding RefundQuantityInput, UpdateSourceTrigger=PropertyChanged}"
                                             HorizontalContentAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             IsEnabled="{Binding CanRefund}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Motivo da devolucao" FontWeight="SemiBold" Margin="0,14,0,6" Foreground="#0F172A"/>
                <TextBox Text="{Binding RefundReason, UpdateSourceTrigger=PropertyChanged}" Height="72" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,14,0,0">
            <StackPanel DockPanel.Dock="Left">
                <ProgressBar Height="6" Width="260" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" Foreground="#334155" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Reimprimir comprovante" Padding="14,8" Margin="0,0,10,0" Click="Reprint_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="Registrar devolucao" Padding="14,8" Click="Refund_Click" Background="#B91C1C" BorderBrush="#B91C1C" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
