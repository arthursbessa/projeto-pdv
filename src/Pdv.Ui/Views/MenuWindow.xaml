<Window x:Class="Pdv.Ui.Views.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Central de Operações do PDV"
        MinHeight="720"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#0B1220">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#111B34" CornerRadius="18" Padding="20" Margin="0,0,0,18">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Border Width="66" Height="66" CornerRadius="12" Background="#0F172A" Margin="0,0,12,0">
                        <Image Source="{Binding StoreLogoPath}" Stretch="Uniform"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding StoreName}" Foreground="#93C5FD" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Menu Operacional" Foreground="White" FontSize="36" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Username, StringFormat=Operador: {0}}" Foreground="#93C5FD" FontSize="16"/>
                    </StackPanel>
                </StackPanel>
                <Border DockPanel.Dock="Right" Background="#1E293B" CornerRadius="10" Padding="16,8" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CashStatus}" Foreground="#FDE68A" FontSize="18" FontWeight="SemiBold"/>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#111827" CornerRadius="16" Padding="18" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Caixas" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,14"/>
                    <Button Content="Abertura de caixa" Click="OpenCashScreen_Click" Height="62" Margin="0,0,0,10" Background="#16A34A" Foreground="White" FontWeight="Bold" FontSize="16" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Encerramento de caixa" Click="CloseCashScreen_Click" Height="62" Margin="0,0,0,10" Background="#DC2626" Foreground="White" FontWeight="Bold" FontSize="16" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Sangria" Click="OpenWithdrawalScreen_Click" Height="62" Background="#F59E0B" Foreground="White" FontWeight="Bold" FontSize="16" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Column="1" Columns="2" Rows="2" Margin="14,0,0,0">
                <Button Content="Acessar PDV" Click="OpenPdv_Click" Margin="10" Background="#2563EB" Foreground="White" FontWeight="Bold" FontSize="18" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Content="Integrar dados" Click="IntegrateData_Click" Margin="10" Background="#7C3AED" Foreground="White" FontWeight="Bold" FontSize="18" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </UniformGrid>
        </Grid>

        <Border Grid.Row="2" Background="#0F172A" CornerRadius="10" Padding="12" Margin="0,16,0,0">
            <StackPanel>
                <ProgressBar Height="6" Margin="0,0,0,8" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" Foreground="#E2E8F0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
