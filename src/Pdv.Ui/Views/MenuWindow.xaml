<Window x:Class="Pdv.Ui.Views.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Central de Operações do PDV" Height="620" Width="980" WindowStartupLocation="CenterScreen" WindowState="Maximized" Background="#E2E8F0">
    <Grid Margin="20">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="#0F172A" CornerRadius="16" Padding="18" Margin="0,0,0,16">
            <DockPanel>
                <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                    <TextBlock Text="Menu Operacional" Foreground="White" FontSize="30" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Username, StringFormat=Operador: {0}}" Foreground="#BFDBFE"/>
                </StackPanel>
                <TextBlock Text="{Binding CashStatus}" Foreground="#FDE68A" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,10,0">
                <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Abertura de caixa" FontWeight="Bold" FontSize="18"/>
                        <TextBox Margin="0,10,0,8" Text="{Binding OpenAmount}"/>
                        <Button Content="Abrir caixa" Height="36" Click="OpenCash_Click" Background="#16A34A" Foreground="White"/>
                    </StackPanel>
                </Border>
                <Border Background="White" CornerRadius="12" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Encerramento de caixa" FontWeight="Bold" FontSize="18"/>
                        <TextBox Margin="0,10,0,8" Text="{Binding CloseAmount}"/>
                        <Button Content="Fechar caixa" Height="36" Click="CloseCash_Click" Background="#DC2626" Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            <UniformGrid Grid.Column="1" Rows="3" Columns="1" Margin="10,0,0,0">
                <Button Content="Acessar PDV" Height="60" Click="OpenPdv_Click" Background="#2563EB" Foreground="White" FontWeight="Bold"/>
                <Button Content="CRUD de Produtos" Height="60" Click="OpenProducts_Click" Background="#0EA5E9" Foreground="White" FontWeight="Bold"/>
                <StackPanel>
                    <Button Content="CRUD de Usuários" Height="60" Click="OpenUsers_Click" Background="#7C3AED" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Button Content="Vendas do caixa aberto" Height="60" Click="OpenSales_Click" Background="#F59E0B" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </UniformGrid>
        </Grid>
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" FontWeight="SemiBold" Margin="0,16,0,0"/>
    </Grid>
</Window>
