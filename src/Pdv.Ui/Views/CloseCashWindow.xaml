<Window x:Class="Pdv.Ui.Views.CloseCashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Encerramento de caixa" Height="260" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#0F172A">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Saldo atual do caixa" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding CurrentCashBalance}" Foreground="White" FontWeight="Bold" FontSize="24" Margin="0,0,0,14"/>
            <TextBlock Text="Confirmar encerramento do caixa atual?" Foreground="White" FontWeight="Bold" FontSize="20" Margin="0,0,0,20"/>
            <Button Content="Fechar caixa" Height="40" Background="#DC2626" Foreground="White" Click="Confirm_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <ProgressBar Height="6" Margin="0,10,0,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Grid>
</Window>
