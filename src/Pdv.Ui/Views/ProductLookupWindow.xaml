<Window x:Class="Pdv.Ui.Views.ProductLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Buscar produto"
        Height="620"
        Width="920"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Busca manual de produtos" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>

        <Grid Grid.Row="1" Margin="0,14,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="QueryTextBox"
                     Height="40"
                     VerticalContentAlignment="Center"
                     FontSize="16"
                     Padding="12,0"
                     Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="QueryTextBox_KeyDown"/>
            <Button Grid.Column="1"
                    Content="Novo produto"
                    Margin="12,0,0,0"
                    Padding="16,10"
                    Background="#64748B"
                    BorderBrush="#64748B"
                    Click="CreateProduct_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Grid.Column="2"
                    Content="Adicionar selecionado"
                    Margin="12,0,0,0"
                    Padding="16,10"
                    Click="AddSelected_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
        </Grid>

        <Border Grid.Row="2" Background="White" CornerRadius="14" Padding="12">
            <DataGrid x:Name="ProductsDataGrid"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      PreviewKeyDown="ProductsDataGrid_PreviewKeyDown"
                      KeyDown="ProductsDataGrid_KeyDown"
                      MouseDoubleClick="ProductsDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Codigo" Binding="{Binding Barcode}" Width="170"/>
                    <DataGridTextColumn Header="Descricao" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Preco" Binding="{Binding PriceFormatted}" Width="130"/>
                    <DataGridTemplateColumn Header="Ações" Width="84">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✎"
                                        Width="28"
                                        Height="28"
                                        Padding="0"
                                        Background="#0F766E"
                                        Foreground="White"
                                        BorderBrush="#0F766E"
                                        Click="EditProduct_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,14,0,0">
            <ProgressBar Height="6" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" Foreground="#334155" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
