<Window x:Class="Pdv.Ui.Views.SalesReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Relatório de vendas" Height="560" Width="980" WindowStartupLocation="CenterOwner" Background="#0F172A">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Vendas realizadas no caixa aberto" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding}"
                  Background="#E2E8F0"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data/Hora" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
                <DataGridTextColumn Header="Venda" Binding="{Binding SaleId}" Width="220"/>
                <DataGridTextColumn Header="Caixa" Binding="{Binding SessionId}" Width="220"/>
                <DataGridTextColumn Header="Data caixa" Binding="{Binding BusinessDate}" Width="120"/>
                <DataGridTextColumn Header="Operador" Binding="{Binding OperatorName}" Width="180"/>
                <DataGridTextColumn Header="Pagamento" Binding="{Binding PaymentMethod}" Width="110"/>
                <DataGridTextColumn Header="Valor" Binding="{Binding TotalFormatted}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
