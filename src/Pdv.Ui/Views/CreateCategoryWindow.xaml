<Window x:Class="Pdv.Ui.Views.CreateCategoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nova Categoria"
        Width="560"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding WindowTitle, FallbackValue=Nova Categoria}" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" Foreground="{Binding StatusBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="White" CornerRadius="18" BorderBrush="#DBEAFE" BorderThickness="1" Padding="18">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Nome *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar"
                    Margin="0,0,8,0"
                    Padding="16,10"
                    Background="#64748B"
                    BorderBrush="#64748B"
                    Foreground="White"
                    Click="Cancel_Click"/>
            <Button Content="Criar"
                    Padding="16,10"
                    Background="#2563EB"
                    BorderBrush="#2563EB"
                    Foreground="White"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
