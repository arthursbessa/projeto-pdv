<Window x:Class="Pdv.Ui.Views.ReceiptDecisionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Comprovante de venda"
        Width="360"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F8FC"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F5FBF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFF16F"/>
                                <Setter TargetName="ButtonBorder" Property="BorderThickness" Value="2.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Comprovante de venda" FontSize="22" FontWeight="Bold" Foreground="#153A73"/>
            <TextBlock Text="Deseja imprimir o comprovante de venda desta operacao?" Margin="0,4,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Background="White"
                BorderBrush="#D7E2F0"
                BorderThickness="1.2"
                CornerRadius="12"
                Padding="16">
            <TextBlock Text="Selecione Sim para imprimir ou Nao para finalizar a venda."
                       Foreground="#334155"
                       FontSize="14"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="NoButton" Content="Nao" Style="{StaticResource SecondaryButtonStyle}" Click="No_Click"/>
            <Button x:Name="YesButton" Content="Sim" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="Yes_Click"/>
        </StackPanel>
    </Grid>
</Window>
