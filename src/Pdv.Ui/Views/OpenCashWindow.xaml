<Window x:Class="Pdv.Ui.Views.OpenCashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Abertura de caixa" Height="260" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#0F172A">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Informe o valor inicial do caixa" Foreground="White" FontWeight="Bold" FontSize="20" Margin="0,0,0,14"/>
            <TextBox x:Name="AmountTextBox" Text="0,00" Height="34" FontSize="16" Margin="0,0,0,16"/>
            <Button Content="Confirmar abertura" Height="40" Background="#16A34A" Foreground="White" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
