<Window x:Class="Pdv.Ui.Views.OpenCashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Abertura de caixa" Height="300" Width="460" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#0F172A">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Saldo do último caixa" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14"/>
            <TextBlock Text="{Binding LastClosedCashBalance}" Foreground="White" FontWeight="Bold" FontSize="24" Margin="0,0,0,14"/>
            <TextBlock Text="Informe o valor inicial do caixa" Foreground="White" FontWeight="Bold" FontSize="20" Margin="0,0,0,14"/>
            <TextBox x:Name="AmountTextBox" Text="0,00" Height="34" FontSize="16" Margin="0,0,0,16" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="Confirmar abertura" Height="40" Background="#16A34A" Foreground="White" Click="Confirm_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <ProgressBar Height="6" Margin="0,10,0,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Grid>
</Window>
