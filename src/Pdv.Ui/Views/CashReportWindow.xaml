<Window x:Class="Pdv.Ui.Views.CashReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Relatório de caixa" Height="560" Width="980" WindowStartupLocation="CenterOwner" Background="#0F172A">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Entradas e saídas do caixa aberto" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,12"/>
        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding Entries}"
                  Background="#E2E8F0"
                  RowBackground="White"
                  AlternatingRowBackground="#F8FAFC">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data/Hora" Binding="{Binding CreatedAt, StringFormat=dd/MM/yyyy HH:mm}" Width="160"/>
                <DataGridTextColumn Header="Tipo" Binding="{Binding Type}" Width="120"/>
                <DataGridTextColumn Header="Referência" Binding="{Binding Reference}" Width="380"/>
                <DataGridTextColumn Header="Valor" Binding="{Binding AmountFormatted}" Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="#111827" CornerRadius="8" Padding="12" Margin="0,12,0,0">
            <TextBlock Text="{Binding TotalBalanceFormatted}" Foreground="#E2E8F0" FontWeight="Bold" FontSize="18"/>
        </Border>
    </Grid>
</Window>
