<Window x:Class="Pdv.Ui.Views.DiscountPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desconto"
        Height="230"
        Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F8FC"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F5FBF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Desconto da venda" FontSize="20" FontWeight="Bold" Foreground="#153A73"/>
            <TextBlock Text="Informe o percentual de desconto." Margin="0,4,0,0" Foreground="#64748B" FontSize="12"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="White" CornerRadius="12" BorderBrush="#D7E2F0" BorderThickness="1.2" Padding="14">
            <StackPanel>
                <TextBlock Text="Desconto (%)" FontWeight="SemiBold" FontSize="13" Foreground="#334155"/>
                <TextBox x:Name="DiscountTextBox"
                         Margin="0,8,0,0"
                         Height="40"
                         FontSize="18"
                         FontWeight="Bold"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         TextChanged="DiscountTextBox_TextChanged"/>
                <TextBlock Text="{Binding PreviewText}" Margin="0,8,0,0" Foreground="#64748B" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,16,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
            <Button Content="Confirmar" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
