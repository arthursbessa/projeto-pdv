<Window x:Class="Pdv.Ui.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Login do PDV" WindowStartupLocation="CenterScreen" WindowState="Maximized" WindowStyle="None" ResizeMode="NoResize" Background="#0F172A">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0B1220" Offset="0"/>
                <GradientStop Color="#172554" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E293B" CornerRadius="24" Padding="40">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Width="96" Height="96" Background="#0F172A" CornerRadius="48" HorizontalAlignment="Left" BorderBrush="#2563EB" BorderThickness="2">
                        <Image Source="{Binding StoreLogoPath}" Stretch="Uniform" Margin="10"/>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="{Binding StoreName}" FontSize="40" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding StoreDocument}" Margin="0,12,0,0" FontSize="20" Foreground="#BFDBFE"/>
                        <TextBlock Text="{Binding StoreAddress}" Margin="0,8,0,0" FontSize="18" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Row="3" Background="#0F172A" CornerRadius="16" Padding="18" Margin="0,24,0,0" VerticalAlignment="Top">
                        <TextBlock Text="Bem-vindo ao ponto de venda. Faça login para abrir o caixa, registrar vendas e enviar integrações com segurança." Foreground="#93C5FD" FontSize="17" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="#111827" CornerRadius="24" Padding="28" VerticalAlignment="Center" MaxWidth="500">
                <StackPanel>
                    <TextBlock Text="Acesso ao Sistema PDV" FontSize="30" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Usuário" Margin="0,24,0,6" Foreground="#BFDBFE" FontSize="14"/>
                    <TextBox Text="{Binding Username}" Height="42" Padding="10,8" FontSize="16" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Text="Senha" Margin="0,12,0,6" Foreground="#BFDBFE" FontSize="14"/>
                    <PasswordBox x:Name="PasswordInput" Height="42" Padding="10,8" FontSize="16" PasswordChanged="PasswordInput_OnPasswordChanged" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Entrar" Height="44" Margin="0,20,0,0" Click="Login_Click" Background="#2563EB" Foreground="White" FontWeight="SemiBold" FontSize="16" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <ProgressBar Height="6" Margin="0,12,0,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,14,0,0" Foreground="#FDE68A" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
