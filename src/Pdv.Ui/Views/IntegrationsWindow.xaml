<Window x:Class="Pdv.Ui.Views.IntegrationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Integrações"
        Height="460"
        Width="760"
        WindowStartupLocation="CenterOwner"
        Background="#0F172A">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Status das integrações" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,14"/>

        <Border Grid.Row="1" Background="#111827" CornerRadius="12" Padding="12">
            <DataGrid ItemsSource="{Binding IntegrationStatuses}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False" BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#1E293B"/>
                        <Setter Property="Foreground" Value="#BFDBFE"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#0B1220"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Integração" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Status" Width="220">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <Button Content="Integrar dados" Height="42" Click="IntegrateData_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Background="#7C3AED" Foreground="White" FontWeight="Bold"/>
            <ProgressBar Height="6" Margin="0,10,0,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#E2E8F0" Margin="0,8,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
