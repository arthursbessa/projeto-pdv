<Window x:Class="Pdv.Ui.Views.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Vendas"
        Height="720"
        Width="1220"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Vendas do PDV" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,10">
            <TextBlock Text="Data" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
            <DatePicker SelectedDate="{Binding SelectedDate}" Width="180"/>
            <Button Content="Carregar" Margin="12,0,0,0" Padding="16,10" Click="LoadHistory_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <TextBlock Text="Ultimos 7 dias, contando hoje." Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#475569"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="0,0,12,0">
                <TextBlock Text="Buscar por texto" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="#334155"/>
                <TextBox Height="40"
                         Padding="12,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                <TextBlock Text="Operador de caixa" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="#334155"/>
                <ComboBox Height="40"
                          ItemsSource="{Binding CashierFilters}"
                          SelectedItem="{Binding SelectedCashierFilter}"/>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Text="Cliente" Margin="0,0,0,6" FontWeight="SemiBold" Foreground="#334155"/>
                <ComboBox Height="40"
                          ItemsSource="{Binding CustomerFilters}"
                          SelectedItem="{Binding SelectedCustomerFilter}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="3" Background="White" CornerRadius="14" Padding="12">
            <DataGrid x:Name="SalesDataGrid"
                      ItemsSource="{Binding Sales}"
                      SelectedItem="{Binding SelectedSale}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      MouseDoubleClick="SalesDataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding CustomerName}" Width="200"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DateText}" Width="150"/>
                    <DataGridTextColumn Header="Produto(s)" Binding="{Binding ProductsSummary}" Width="*"/>
                    <DataGridTextColumn Header="Caixa" Binding="{Binding CashierName}" Width="180"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalFormatted}" Width="110"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,14,0,0">
            <StackPanel DockPanel.Dock="Left">
                <ProgressBar Height="6" Width="280" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" Foreground="#334155" TextWrapping="Wrap"/>
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Content="Acessar venda"
                    Padding="16,10"
                    Click="OpenSale_Click"
                    IsEnabled="{Binding CanOpenSelectedSale}"/>
        </DockPanel>
    </Grid>
</Window>
