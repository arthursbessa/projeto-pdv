<Window x:Class="Pdv.Ui.Views.ReceiptPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CPF/CNPJ do comprovante"
        Height="250"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F8FC"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F5FBF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="CPF/CNPJ do comprovante" FontSize="22" FontWeight="Bold" Foreground="#153A73"/>
            <TextBlock Text="Opcional. Se quiser, informe CPF ou CNPJ para imprimir no comprovante." Margin="0,4,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Background="White"
                BorderBrush="#D7E2F0"
                BorderThickness="1.2"
                CornerRadius="12"
                Padding="14">
            <StackPanel>
                <TextBlock Text="CPF ou CNPJ" FontWeight="SemiBold" FontSize="13" Foreground="#334155"/>
                <TextBox x:Name="TaxIdTextBox"
                         Margin="0,8,0,0"
                         Height="40"
                         FontSize="16"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         TextChanged="TaxIdTextBox_TextChanged"/>
                <TextBlock Text="Deixe em branco se nao quiser informar." Margin="0,6,0,0" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
            <Button Content="Imprimir" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
