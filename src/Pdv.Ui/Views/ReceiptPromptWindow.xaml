<Window x:Class="Pdv.Ui.Views.ReceiptPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cupom fiscal"
        Height="450"
        Width="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F8FC"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F5FBF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Cupom fiscal" FontSize="22" FontWeight="Bold" Foreground="#153A73"/>
            <TextBlock Text="Deseja imprimir o cupom fiscal desta venda?" Margin="0,4,0,0" Foreground="#64748B" FontSize="13" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Background="White"
                BorderBrush="#D7E2F0"
                BorderThickness="1.2"
                CornerRadius="12"
                Padding="14">
            <StackPanel>
                <CheckBox x:Name="PrintReceiptCheckBox"
                          Content="Sim, imprimir cupom fiscal"
                          FontSize="14"
                          FontWeight="SemiBold"
                          Foreground="#0F172A"
                          Checked="PrintReceiptCheckBox_Changed"
                          Unchecked="PrintReceiptCheckBox_Changed"/>
                <TextBlock Text="Se marcado, voce pode informar CPF ou CNPJ opcionalmente." Margin="0,6,0,0" Foreground="#64748B" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Background="White"
                BorderBrush="#D7E2F0"
                BorderThickness="1.2"
                CornerRadius="12"
                Padding="14"
                MinHeight="92"
                Visibility="{Binding IsChecked, ElementName=PrintReceiptCheckBox, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="CPF ou CNPJ no cupom" FontWeight="SemiBold" FontSize="13" Foreground="#334155"/>
                <TextBox x:Name="TaxIdTextBox"
                         Margin="0,8,0,0"
                         Height="42"
                         FontSize="16"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         TextChanged="TaxIdTextBox_TextChanged"/>
                <TextBlock Text="Opcional. O campo aceita CPF ou CNPJ e aplica a máscara automaticamente." Margin="0,6,0,0" Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"/>
            <Button Content="Confirmar" Margin="10,0,0,0" Style="{StaticResource PrimaryButtonStyle}" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
