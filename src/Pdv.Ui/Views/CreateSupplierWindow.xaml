<Window x:Class="Pdv.Ui.Views.CreateSupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Novo Fornecedor"
        Width="760"
        Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Novo Fornecedor" FontSize="24" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,6,0,0" Foreground="{Binding StatusBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Background="White" CornerRadius="18" BorderBrush="#DBEAFE" BorderThickness="1" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,14">
                        <TextBlock Text="Razão Social *" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,14">
                        <TextBlock Text="CNPJ" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox x:Name="CnpjTextBox" Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Cnpj, UpdateSourceTrigger=PropertyChanged}" TextChanged="CnpjTextBox_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,14">
                        <TextBlock Text="Prazo Médio (dias)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding AvgDeliveryDays, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,14">
                        <TextBlock Text="Contato" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="12,0,0,14">
                        <TextBlock Text="Telefone" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="E-mail" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="40" Padding="12,0" VerticalContentAlignment="Center" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Observações" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Height="96" Padding="12,8" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar"
                    Margin="0,0,8,0"
                    Padding="16,10"
                    Background="#64748B"
                    BorderBrush="#64748B"
                    Foreground="White"
                    Click="Cancel_Click"/>
            <Button Content="Criar"
                    Padding="16,10"
                    Background="#2563EB"
                    BorderBrush="#2563EB"
                    Foreground="White"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
