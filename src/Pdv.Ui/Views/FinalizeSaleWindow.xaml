<Window x:Class="Pdv.Ui.Views.FinalizeSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Finalizar venda"
        Height="840"
        Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F8FC"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1F5FBF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>

        <Style x:Key="TopActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#94A3B8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinWidth" Value="122"/>
        </Style>

        <Style x:Key="SummaryMetricBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#D7E2F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="PaymentRowStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Row"
                                Background="White"
                                BorderBrush="#D7E2F0"
                                BorderThickness="1.2"
                                CornerRadius="10"
                                Padding="14,10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="32"
                                        Height="32"
                                        CornerRadius="8"
                                        Background="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ContentPresenter ContentSource="Content"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A"
                                           Text="{Binding ToolTip, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Ellipse x:Name="Dot"
                                         Grid.Column="2"
                                         Width="14"
                                         Height="14"
                                         Fill="#CBD5E1"
                                         VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Row" Property="BorderBrush" Value="#1F5FBF"/>
                                <Setter TargetName="Dot" Property="Fill" Value="#1F5FBF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Finalizacao de venda"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#153A73"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Margin="0,0,10,0"
                    Style="{StaticResource TopActionButtonStyle}"
                    Click="Discount_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding DiscountButtonText}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding DiscountShortcutLabel, StringFormat=({0})}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource TopActionButtonStyle}"
                    Click="SelectCustomer_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding CustomerButtonText}" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CustomerShortcutLabel, StringFormat=({0})}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
        

        <Border Grid.Row="2"
                Margin="0,12,0,0"
                Background="White"
                CornerRadius="14"
                BorderBrush="#D7E2F0"
                BorderThickness="1.2"
                Padding="14">
            <StackPanel>
                <Border Style="{StaticResource SummaryMetricBorderStyle}"
                        Visibility="{Binding HasDiscountApplied, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Valor da venda"
                                   FontSize="11"
                                   Foreground="#64748B"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SaleValueFormatted}"
                                   FontSize="22"
                                   Foreground="#153A73"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryMetricBorderStyle}"
                        Visibility="{Binding HasDiscountApplied, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="Desconto aplicado"
                                   FontSize="11"
                                   Foreground="#B45309"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DiscountAppliedFormatted}"
                                   FontSize="18"
                                   Foreground="#B45309"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="#EEF4FF"
                        BorderBrush="#BFD3FF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16,12"
                        Margin="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="Valor final"
                                   FontSize="11"
                                   Foreground="#1F5FBF"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalWithDiscountFormatted}"
                                   FontSize="30"
                                   Foreground="#153A73"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding SelectedCustomerDisplay}"
                           FontSize="12"
                           Foreground="#475569"
                           Margin="2,10,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock Text="Selecione a forma de pagamento"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="#0F172A"
                       Margin="0,0,0,12"/>

            <RadioButton x:Name="CashOption"
                         ToolTip="Dinheiro"
                         Tag="#16A34A"
                         GroupName="PaymentMethod"
                         Checked="PaymentOption_Checked"
                         Style="{StaticResource PaymentRowStyle}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="1" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </RadioButton>

            <Border Margin="0,-2,0,8"
                    Padding="12,10"
                    Background="#F0FDF4"
                    BorderBrush="#BBF7D0"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,10,10"
                    Visibility="{Binding IsCashSelected, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Valor recebido"
                                   FontSize="11"
                                   Foreground="#166534"
                                   FontWeight="SemiBold"/>
                        <TextBox x:Name="ReceivedAmountTextBox"
                                 Margin="0,4,0,0"
                                 Height="34"
                                 VerticalContentAlignment="Center"
                                 FontSize="15"
                                 Padding="8,0"
                                 Text="{Binding ReceivedAmountInput, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                        <TextBlock Text="{Binding CashValidationMessage}"
                                   Foreground="#DC2626"
                                   FontSize="10"
                                   Margin="0,3,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Margin="16,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <TextBlock Text="Troco"
                                   FontSize="11"
                                   Foreground="#166534"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding ChangeFormatted}"
                                   FontWeight="Bold"
                                   FontSize="22"
                                   Foreground="#15803D"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <RadioButton x:Name="PixOption"
                         ToolTip="PIX"
                         Tag="#0EA5E9"
                         GroupName="PaymentMethod"
                         Checked="PaymentOption_Checked"
                         Style="{StaticResource PaymentRowStyle}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="2" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
            </RadioButton>

            <RadioButton x:Name="CreditCardOption"
                         ToolTip="Cartao de credito"
                         Tag="#7C3AED"
                         GroupName="PaymentMethod"
                         Checked="PaymentOption_Checked"
                         Style="{StaticResource PaymentRowStyle}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="3" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </RadioButton>

            <RadioButton x:Name="DebitCardOption"
                         ToolTip="Cartao de debito"
                         Tag="#EA580C"
                         GroupName="PaymentMethod"
                         Checked="PaymentOption_Checked"
                         Style="{StaticResource PaymentRowStyle}"
                         IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                <TextBlock Text="4" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </RadioButton>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ProgressBar Grid.Column="0"
                         Height="5"
                         VerticalAlignment="Center"
                         IsIndeterminate="True"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="1"
                    Content="Cancelar"
                    Margin="8,0,0,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="Cancel_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Grid.Column="2"
                    Content="Voltar"
                    Margin="8,0,0,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="Back_Click"
                    Visibility="{Binding ShowBackButton, Converter={StaticResource BoolToVisibility}}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Grid.Column="3"
                    Content="Finalizar venda"
                    Margin="8,0,0,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="PrimaryAction_Click"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
        </Grid>
    </Grid>
</Window>
