<Window x:Class="Pdv.Ui.Views.FinalizeSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="Finalizar venda" Height="620" Width="500" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#EFF6FF" KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Finalizacao de pagamento" FontSize="22" FontWeight="Bold" Foreground="#1E3A8A"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="{Binding TotalFormatted, StringFormat=Total da venda: {0}}" Foreground="#334155" FontWeight="SemiBold"/>

        <ScrollViewer Grid.Row="2" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
            <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,4,0">
                <StackPanel>
                    <RadioButton x:Name="CashOption" Content="Dinheiro" IsChecked="True" Margin="0,0,0,8" FontSize="15" Checked="PaymentOption_Checked" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <RadioButton x:Name="CardOption" Content="Cartao" Margin="0,0,0,8" FontSize="15" Checked="PaymentOption_Checked" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <RadioButton x:Name="PixOption" Content="PIX" FontSize="15" Checked="PaymentOption_Checked" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>

                    <Border Margin="0,14,0,0"
                            Padding="12"
                            Background="#EFF6FF"
                            CornerRadius="10"
                            Visibility="{Binding IsCashSelected, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Valor recebido" FontWeight="SemiBold" Foreground="#1E293B"/>
                            <TextBox x:Name="ReceivedAmountTextBox"
                                     Margin="0,8,0,0"
                                     Height="38"
                                     VerticalContentAlignment="Center"
                                     FontSize="16"
                                     Padding="10,0"
                                     Text="{Binding ReceivedAmountInput, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                            <TextBlock Text="Troco" Margin="0,12,0,0" FontWeight="SemiBold" Foreground="#0F766E"/>
                            <TextBlock Text="{Binding ChangeFormatted}" Margin="0,4,0,0" FontWeight="Bold" FontSize="32" Foreground="#065F46"/>
                            <TextBlock Text="{Binding CashValidationMessage}" Margin="0,6,0,0" Foreground="#B91C1C" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Separator Margin="0,12,0,10"/>
                    <Border Background="#E0F2FE" BorderBrush="#38BDF8" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,4">
                        <CheckBox x:Name="PrintCouponOption"
                                  Content="Imprimir cupom fiscal"
                                  FontSize="16"
                                  FontWeight="Bold"
                                  Foreground="#0C4A6E"
                                  IsChecked="True"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Cancelar (ESC)" Padding="14,8" Margin="0,0,8,0" Click="Cancel_Click" Background="#64748B" BorderBrush="#64748B" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Content="Confirmar (ENTER)" Padding="14,8" Click="Confirm_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
        </StackPanel>

        <ProgressBar Grid.Row="3" Height="6" Margin="0,48,0,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</Window>
