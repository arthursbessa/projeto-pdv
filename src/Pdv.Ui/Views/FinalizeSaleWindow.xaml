<Window x:Class="Pdv.Ui.Views.FinalizeSaleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Finalizar venda" Height="260" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F3F5F7" KeyDown="Window_KeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Finalização de pagamento" FontSize="20" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="Selecione a forma de pagamento" Foreground="#4B5563"/>

        <StackPanel Grid.Row="2" Margin="0,14,0,0">
            <RadioButton x:Name="CashOption" Content="Dinheiro" IsChecked="True" Margin="0,0,0,8"/>
            <RadioButton x:Name="CardOption" Content="Cartão" Margin="0,0,0,8"/>
            <RadioButton x:Name="PixOption" Content="PIX"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancelar (ESC)" Padding="12,6" Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="Confirmar (ENTER)" Padding="12,6" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
