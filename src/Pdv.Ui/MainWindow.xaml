<Window x:Class="Pdv.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="PDV Local"
        Height="900"
        Width="1440"
        MinHeight="820"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        KeyDown="Window_KeyDown"
        Background="#0B1730">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>

        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#081325" Offset="0"/>
            <GradientStop Color="#0F3A68" Offset="0.55"/>
            <GradientStop Color="#10A4D8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#163B6B"/>
            <Setter Property="BorderBrush" Value="#5BC0FF"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#123766"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#3CB9FF"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}"/>

        <Style x:Key="InlineEditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,18"
                    Padding="16"
                    CornerRadius="22"
                    Background="#0A1A32"
                    BorderBrush="#2AA8E8"
                    BorderThickness="1.4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="4,0,18,0">
                        <TextBlock Text="ULTIMO PRODUTO ESCANEADO" Foreground="#8DDCFF" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LastScannedDescription}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,10,0,0">
                            <TextBlock Text="{Binding LastScannedBarcode, StringFormat=Codigo: {0}}" Foreground="#D6F5FF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="   |   " Foreground="#4DBFFF" FontSize="13"/>
                            <TextBlock Text="{Binding LastScannedQuantityText}" Foreground="#D6F5FF" FontSize="13" FontWeight="SemiBold"/>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="160"
                            Height="92"
                            HorizontalAlignment="Right"
                            CornerRadius="18"
                            Background="#0B1C37"
                            BorderBrush="#47C4FF"
                            BorderThickness="1.2"
                            VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Valor atual" Foreground="#8DDCFF" FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding LastScannedPriceFormatted}" Foreground="#FFF16F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" MinHeight="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource MetricCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Unitario" Foreground="#D8F3FF" FontSize="16" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1"
                                     x:Name="SelectedPriceTextBox"
                                     Style="{StaticResource InlineEditorTextBoxStyle}"
                                     FontSize="20"
                                     Background="White"
                                     BorderBrush="#7DD3FC"
                                     Foreground="#0F172A"
                                     IsEnabled="{Binding CanEditSelectedItem}"
                                     LostFocus="SelectedPriceTextBox_LostFocus"
                                     KeyDown="SelectedPriceTextBox_KeyDown"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource MetricCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Qtd" Foreground="#D8F3FF" FontSize="16" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1"
                                     x:Name="SelectedQuantityTextBox"
                                     Style="{StaticResource InlineEditorTextBoxStyle}"
                                     FontSize="20"
                                     Background="White"
                                     BorderBrush="#7DD3FC"
                                     Foreground="#0F172A"
                                     IsEnabled="{Binding CanEditSelectedItem}"
                                     LostFocus="SelectedQuantityTextBox_LostFocus"
                                     KeyDown="SelectedQuantityTextBox_KeyDown"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource MetricCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Descontos" Foreground="#D8F3FF" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{Binding DiscountFormatted}" Foreground="White" FontSize="22" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Margin="0,14,0,0"
                            Padding="22"
                            CornerRadius="24"
                            Background="#0A2344"
                            BorderBrush="#3DC6FF"
                            BorderThickness="1.5">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TOTAL" Foreground="#FFF16F" FontSize="26" FontWeight="Bold"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Itens" Foreground="#8DDCFF" FontSize="12" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding ItemCountFormatted}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="{Binding TotalFormatted}"
                                       Margin="0,18,0,0"
                                       Foreground="White"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        Margin="0,0,18,0"
                        Padding="24"
                        CornerRadius="34"
                        Background="#F8FAFC"
                        BorderBrush="#D6E6F7"
                        BorderThickness="2">
                    <Grid>
                        <Border Background="White"
                                CornerRadius="26"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1.4"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Margin="4,2,4,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="115"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Codigo" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Descricao do produto" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Qtd" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="Preco" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="Subtotal" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Grid>

                                <DataGrid Grid.Row="1"
                                          x:Name="ItemsDataGrid"
                                          ItemsSource="{Binding Items}"
                                          SelectedItem="{Binding SelectedItem}"
                                          SelectionChanged="ItemsDataGrid_SelectionChanged"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="None"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="#F8FAFC"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="8,10"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="#0F172A"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Codigo" Binding="{Binding Barcode}" Width="150" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Descricao" Binding="{Binding DisplayDescription}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="90" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Preco" Binding="{Binding Price, StringFormat=R$ {0:N2}}" Width="110" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=R$ {0:N2}}" Width="115" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="18"
                        CornerRadius="24"
                        Background="#0B1C37"
                        BorderBrush="#58C8FF"
                        BorderThickness="1.4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Painel operacional" Foreground="White" FontSize="22" FontWeight="Bold"/>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <Button Click="Finalize_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Fechar venda" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FinalizeShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Click="SearchProduct_Click" Background="#0F766E" BorderBrush="#34D399" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Buscar produto" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SearchProductShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding RemoveSelectedCommand}" Background="#475569" BorderBrush="#CBD5E1" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Cancelar item" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RemoveItemShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding CancelSaleCommand}" Background="#B91C1C" BorderBrush="#FCA5A5">
                                <StackPanel>
                                    <TextBlock Text="Cancelar cupom" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CancelSaleShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,18,0,0">
                            <ProgressBar Height="6"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Margin="0,10,0,0" Text="{Binding StatusMessage}" Foreground="#D6F5FF" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="16"
                    CornerRadius="24"
                    Background="#0A1A32"
                    BorderBrush="#2AA8E8"
                    BorderThickness="1.2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Entre com o codigo de barras do produto"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBox x:Name="BarcodeTextBox"
                                 Height="48"
                                 Margin="0,10,0,0"
                                 VerticalContentAlignment="Center"
                                 FontSize="22"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="BarcodeTextBox_KeyDown"
                                 Padding="14,0"
                                 BorderBrush="#7DD3FC"
                                 BorderThickness="1.5"
                                 Background="#F8FAFC"
                                 Foreground="#0F172A"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Margin="0,28,12,0"
                            Padding="14,12"
                            Click="AddItem_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel>
                            <TextBlock Text="Adicionar item" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AddItemShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Margin="0,28,0,0"
                            Padding="14,12"
                            Click="SearchProduct_Click"
                            Background="#0F766E"
                            BorderBrush="#34D399"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                        <StackPanel>
                            <TextBlock Text="Buscar produto" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SearchProductShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
