<Window x:Class="Pdv.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDV Local" Height="840" Width="1320" WindowStartupLocation="CenterScreen" WindowState="Maximized" KeyDown="Window_KeyDown" Background="#F1F5F9">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Margin="0,0,0,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0B1120" Offset="0"/>
                    <GradientStop Color="#111C44" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="22,18">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Border Width="58" Height="58" CornerRadius="10" Background="#0F172A" Margin="0,0,12,0">
                        <Image Source="{Binding StoreLogoPath}" Stretch="Uniform"/>
                    </Border>
                    <TextBlock Text="PDV" Foreground="White" FontSize="38" FontWeight="Bold" Margin="0,0,14,0"/>
                    <StackPanel>
                        <TextBlock Text="{Binding StoreName}" Foreground="#93C5FD" FontWeight="SemiBold" FontSize="14"/>
                        <Border Background="#2563EB" CornerRadius="10" Padding="12,6" Margin="0,4,0,0">
                            <TextBlock Text="{Binding OfflineStatus}" Foreground="White" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Itens" Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ItemCount}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,24,0"/>
                    <TextBlock Text="Total" Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TotalFormatted}" Foreground="#FDE68A" FontSize="42" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Codigo de barras" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="BarcodeTextBox" Grid.Column="1" Height="40" VerticalContentAlignment="Center" FontSize="17"
                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}" KeyDown="BarcodeTextBox_KeyDown"
                         BorderBrush="#93C5FD" BorderThickness="1.5" Padding="10,0"/>
                <Button Grid.Column="2" Content="Adicionar (ENTER)" Margin="12,0,0,0" Padding="16,8" Click="AddItem_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Button Grid.Column="3" Content="Buscar produto (F3)" Margin="12,0,0,0" Padding="16,8" Click="SearchProduct_Click" Background="#0F766E" BorderBrush="#0F766E" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                <Border Grid.Column="5" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="10" Padding="12,8">
                    <StackPanel>
                        <TextBlock Text="Cliente" FontSize="12" Foreground="#64748B" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedCustomerDisplay}" FontSize="14" FontWeight="Bold" Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SelectedCustomerHint}" FontSize="11" Foreground="#475569"/>
                    </StackPanel>
                </Border>
                <Button Grid.Column="6" Content="Buscar cliente (F7)" Margin="12,0,0,0" Padding="16,8" Click="SearchCustomer_Click" Background="#7C3AED" BorderBrush="#7C3AED" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" CornerRadius="18" Padding="18" Margin="0,0,0,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1D4ED8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Ultimo produto escaneado" Foreground="#BFDBFE" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding LastScannedDescription}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="18,0,0,0">
                    <TextBlock Text="Codigo" Foreground="#BFDBFE" FontSize="13"/>
                    <TextBlock Text="{Binding LastScannedBarcode}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="18,0,0,0">
                    <TextBlock Text="Preco" Foreground="#BFDBFE" FontSize="13"/>
                    <TextBlock Text="{Binding LastScannedPriceFormatted}" Foreground="#FDE68A" FontSize="20" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="18,0,0,0">
                    <TextBlock Text="Situacao" Foreground="#BFDBFE" FontSize="13"/>
                    <TextBlock Text="{Binding LastScannedQuantityText}" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="12" Margin="0,0,14,0">
                <DataGrid x:Name="ItemsDataGrid" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False"
                          AlternatingRowBackground="#F8FAFC" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserAddRows="False" CellEditEnding="ItemsDataGrid_CellEditEnding" BorderBrush="#BFDBFE" BorderThickness="1">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#EFF6FF"/>
                            <Setter Property="Foreground" Value="#1E3A8A"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Codigo" Binding="{Binding Barcode}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Descricao" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Preco" Binding="{Binding Price, StringFormat=R$ {0:N2}}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=R$ {0:N2}}" Width="130" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="Acoes" FontWeight="Bold" FontSize="20" Margin="0,0,0,12"/>
                    <Button Content="Finalizar venda (F2)" Margin="0,0,0,10" Padding="12" Click="Finalize_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Buscar produto (F3)" Margin="0,0,0,10" Padding="12" Click="SearchProduct_Click" Background="#0F766E" BorderBrush="#0F766E" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Selecionar cliente (F7)" Margin="0,0,0,10" Padding="12" Click="SearchCustomer_Click" Background="#7C3AED" BorderBrush="#7C3AED" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Quantidade" Margin="0,0,0,10" Padding="12" Click="ChangeQuantity_Click" Background="#0EA5E9" BorderBrush="#0EA5E9" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Remover item (F4)" Margin="0,0,0,10" Padding="12" Command="{Binding RemoveSelectedCommand}" Background="#334155" BorderBrush="#334155" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                    <Button Content="Cancelar venda (ESC)" Padding="12" Command="{Binding CancelSaleCommand}" Background="#B91C1C" BorderBrush="#B91C1C"/>
                    <Separator Margin="0,16"/>
                    <TextBlock Text="Resumo" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding ItemCount, StringFormat=Itens: {0}}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding TotalFormatted, StringFormat=Total: {0}}" FontSize="26" FontWeight="Bold" Margin="0,8,0,0" Foreground="#1D4ED8"/>
                    <ProgressBar Height="6" Margin="0,12,0,0" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,16,0,0" Foreground="#334155"/>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="4" Margin="0,12,0,0" Background="#E2E8F0">
            <StatusBarItem>
                <TextBlock Text="ENTER adiciona | F2 finaliza | F3 busca produto | F4 remove | F6 quantidade | F7 cliente | ESC cancela | CTRL+F foco codigo"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding DatabaseStatus}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
