<Window x:Class="Pdv.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDV Local" Height="760" Width="1240" WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown" Background="#EEF2F6">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A" CornerRadius="12" Padding="18" Margin="0,0,0,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="PDV" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,12,0"/>
                    <Border Background="#1D4ED8" CornerRadius="8" Padding="10,4">
                        <TextBlock Text="{Binding OfflineStatus}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="Itens" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ItemCount}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,20,0"/>
                    <TextBlock Text="Total" Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding TotalFormatted}" Foreground="#FDE68A" FontSize="36" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="420"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Código de barras" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
                <TextBox x:Name="BarcodeTextBox" Grid.Column="1" Height="34" VerticalContentAlignment="Center" FontSize="16"
                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                         PreviewKeyDown="BarcodeTextBox_PreviewKeyDown" KeyDown="BarcodeTextBox_KeyDown"/>
                <Button Grid.Column="2" Content="Adicionar (ENTER)" Margin="12,0,0,0" Padding="14,6" Click="AddItem_Click"/>
                <Button Grid.Column="3" Content="Produtos" Margin="8,0,0,0" Padding="14,6" Click="OpenProducts_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="12" Margin="0,0,12,0">
                <DataGrid x:Name="ItemsDataGrid" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False"
                          AlternatingRowBackground="#F8FAFC" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserAddRows="False" CellEditEnding="ItemsDataGrid_CellEditEnding">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Barcode}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Preço" Binding="{Binding Price, StringFormat=R$ {0:N2}}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=R$ {0:N2}}" Width="130" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="14">
                <StackPanel>
                    <TextBlock Text="Ações" FontWeight="Bold" FontSize="18" Margin="0,0,0,12"/>
                    <Button Content="Finalizar Venda (F2)" Margin="0,0,0,8" Padding="12" Click="Finalize_Click"/>
                    <Button Content="Remover Item (F4)" Margin="0,0,0,8" Padding="12" Command="{Binding RemoveSelectedCommand}"/>
                    <Button Content="Cancelar Venda (ESC)" Padding="12" Command="{Binding CancelSaleCommand}"/>
                    <Separator Margin="0,14"/>
                    <TextBlock Text="Resumo" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding ItemCount, StringFormat=Itens: {0}}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding TotalFormatted, StringFormat=Total: {0}}" FontSize="24" FontWeight="Bold" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Margin="0,12,0,0">
            <StatusBarItem>
                <TextBlock Text="ENTER Adiciona | F2 Finaliza | F4 Remove | ESC Cancela | CTRL+F Foco código"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding DatabaseStatus}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
