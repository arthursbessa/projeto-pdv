<Window x:Class="Pdv.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:Pdv.Ui.Converters"
        Title="PDV Local"
        Height="900"
        Width="1440"
        MinHeight="820"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown"
        Background="#0B1730">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter"/>

        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#081325" Offset="0"/>
            <GradientStop Color="#0F3A68" Offset="0.55"/>
            <GradientStop Color="#10A4D8" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="Background" Value="#163B6B"/>
            <Setter Property="BorderBrush" Value="#5BC0FF"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FFF16F"/>
                    <Setter Property="BorderThickness" Value="2.6"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#123766"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderBrush" Value="#3CB9FF"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="MetricCardInnerBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#0A2344"/>
            <Setter Property="BorderBrush" Value="#2AA8E8"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="BorderBrush" Value="#FFF16F"/>
                    <Setter Property="BorderThickness" Value="2.8"/>
                    <Setter Property="Background" Value="#102B50"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}"/>

        <Style x:Key="InlineEditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="BorderBrush" Value="#8BD8FF"/>
            <Setter Property="BorderThickness" Value="1.6"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#FFF16F"/>
                    <Setter Property="BorderThickness" Value="2.8"/>
                    <Setter Property="Background" Value="#FFFDEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MainBarcodeTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InlineEditorTextBoxStyle}">
            <Setter Property="Height" Value="56"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="IsTabStop" Value="False"/>
        </Style>

        <Style x:Key="ItemsDataGridStyle" TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="#D7E2F0"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="#FFF16F"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="0,0,0,18"
                    Padding="16"
                    CornerRadius="22"
                    Background="#0A1A32"
                    BorderBrush="#2AA8E8"
                    BorderThickness="1.4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="190"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="4,0,18,0">
                        <TextBlock Text="ULTIMO PRODUTO ESCANEADO" Foreground="#8DDCFF" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding LastScannedDescription}" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,10,0,0">
                            <TextBlock Text="{Binding LastScannedBarcode, StringFormat=Codigo: {0}}" Foreground="#D6F5FF" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="   |   " Foreground="#4DBFFF" FontSize="13"/>
                            <TextBlock Text="{Binding LastScannedQuantityText}" Foreground="#D6F5FF" FontSize="13" FontWeight="SemiBold"/>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="160"
                            Height="92"
                            HorizontalAlignment="Right"
                            CornerRadius="18"
                            Background="#0B1C37"
                            BorderBrush="#47C4FF"
                            BorderThickness="1.2"
                            VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Valor atual" Foreground="#8DDCFF" FontSize="13" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding LastScannedPriceFormatted}" Foreground="#FFF16F" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" MinHeight="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,18,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource MetricCardInnerBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Valor unitario" Foreground="#D8F3FF" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ChangePriceShortcutLabel, StringFormat=({0})}" Foreground="#9EDCFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <TextBox x:Name="SelectedPriceTextBox"
                                     Margin="0,18,0,0"
                                     Style="{StaticResource InlineEditorTextBoxStyle}"
                                     Background="#F8FBFF"
                                     BorderBrush="#7DD3FC"
                                     Foreground="#0F172A"
                                     IsEnabled="{Binding CanEditSelectedItem}"
                                     LostFocus="SelectedPriceTextBox_LostFocus"
                                     KeyDown="SelectedPriceTextBox_KeyDown"
                                     GotKeyboardFocus="FocusableElement_GotKeyboardFocus"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource MetricCardInnerBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Quantidade" Foreground="#D8F3FF" FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ChangeQuantityShortcutLabel, StringFormat=({0})}" Foreground="#9EDCFF" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <TextBox x:Name="SelectedQuantityTextBox"
                                     Margin="0,18,0,0"
                                     Style="{StaticResource InlineEditorTextBoxStyle}"
                                     Background="#F8FBFF"
                                     BorderBrush="#7DD3FC"
                                     Foreground="#0F172A"
                                     IsEnabled="{Binding CanEditSelectedItem}"
                                     LostFocus="SelectedQuantityTextBox_LostFocus"
                                     KeyDown="SelectedQuantityTextBox_KeyDown"
                                     GotKeyboardFocus="FocusableElement_GotKeyboardFocus"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Padding="22"
                                CornerRadius="24"
                                Background="#0A2344"
                                BorderBrush="#3DC6FF"
                                BorderThickness="1.5">
                            <StackPanel>
                                <TextBlock Text="ITENS NA VENDA" Foreground="#8DDCFF" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ItemCountFormatted}"
                                           Margin="0,10,0,0"
                                           Foreground="White"
                                           FontSize="42"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1"
                                Margin="0,14,0,0"
                                Padding="22"
                                CornerRadius="24"
                                Background="#0F2E57"
                                BorderBrush="#5BC0FF"
                                BorderThickness="1.5">
                            <StackPanel>
                                <TextBlock Text="TOTAL DA VENDA" Foreground="#FFF16F" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="{Binding TotalFormatted}"
                                           Margin="0,12,0,0"
                                           Foreground="White"
                                           FontSize="36"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Border Grid.Column="1"
                        Margin="0,0,18,0"
                        Padding="24"
                        CornerRadius="34"
                        Background="#F8FAFC"
                        BorderBrush="#D6E6F7"
                        BorderThickness="2">
                    <Grid>
                        <Border Background="White"
                                CornerRadius="26"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1.4"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Margin="4,2,4,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="115"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Codigo" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Descricao do produto" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Qtd" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="Preco" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="Subtotal" Foreground="#475569" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </Grid>

                                <DataGrid Grid.Row="1"
                                          x:Name="ItemsDataGrid"
                                          Style="{StaticResource ItemsDataGridStyle}"
                                          ItemsSource="{Binding Items}"
                                          SelectedItem="{Binding SelectedItem}"
                                          SelectionChanged="ItemsDataGrid_SelectionChanged"
                                          GotKeyboardFocus="FocusableElement_GotKeyboardFocus"
                                          IsTabStop="True"
                                          AutoGenerateColumns="False"
                                          HeadersVisibility="None"
                                          GridLinesVisibility="Horizontal"
                                          AlternatingRowBackground="#F8FAFC"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridCell">
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Padding" Value="8,10"/>
                                        </Style>
                                        <Style TargetType="DataGridRow">
                                            <Setter Property="Foreground" Value="#0F172A"/>
                                            <Setter Property="FontSize" Value="14"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#DCEEFF"/>
                                                    <Setter Property="Foreground" Value="#0F172A"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="BorderBrush" Value="#1F5FBF"/>
                                                    <Setter Property="BorderThickness" Value="0,0,0,0"/>
                                                </Trigger>
                                                <MultiTrigger>
                                                    <MultiTrigger.Conditions>
                                                        <Condition Property="IsSelected" Value="True"/>
                                                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                                                    </MultiTrigger.Conditions>
                                                    <Setter Property="Background" Value="#CDE5FF"/>
                                                </MultiTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Codigo" Binding="{Binding Barcode}" Width="150" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Descricao" Binding="{Binding DisplayDescription}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="90" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Preco" Binding="{Binding Price, StringFormat=R$ {0:N2}}" Width="110" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=R$ {0:N2}}" Width="115" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="18"
                        CornerRadius="24"
                        Background="#0B1C37"
                        BorderBrush="#58C8FF"
                        BorderThickness="1.4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Painel operacional" Foreground="White" FontSize="22" FontWeight="Bold"/>

                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <Button x:Name="FinalizeButton" Click="Finalize_Click" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" GotKeyboardFocus="FocusableElement_GotKeyboardFocus" IsTabStop="False">
                                <StackPanel>
                                    <TextBlock Text="Fechar venda" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FinalizeShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="ReprintLastSaleButton" Click="ReprintLastSale_Click" Background="#7C3AED" BorderBrush="#C4B5FD" IsEnabled="{Binding CanReprintLastSale}" GotKeyboardFocus="FocusableElement_GotKeyboardFocus" IsTabStop="False">
                                <StackPanel>
                                    <TextBlock Text="Reimprimir ultima venda" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding ReprintLastSaleShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="RemoveItemButton" Command="{Binding RemoveSelectedCommand}" Background="#475569" BorderBrush="#CBD5E1" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" GotKeyboardFocus="FocusableElement_GotKeyboardFocus" IsTabStop="False">
                                <StackPanel>
                                    <TextBlock Text="Remover item" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RemoveItemShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="CancelSaleButton" Click="CancelSale_Click" Background="#B91C1C" BorderBrush="#FCA5A5" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" GotKeyboardFocus="FocusableElement_GotKeyboardFocus" IsTabStop="False">
                                <StackPanel>
                                    <TextBlock Text="Cancelar comprovante" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CancelSaleShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Margin="0,18,0,0">
                            <ProgressBar Height="6"
                                         IsIndeterminate="True"
                                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Margin="0,10,0,0" Text="{Binding StatusMessage}" Foreground="#D6F5FF" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Margin="0,18,0,0"
                    Padding="16"
                    CornerRadius="24"
                    Background="#0A1A32"
                    BorderBrush="#2AA8E8"
                    BorderThickness="1.2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="170"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,16,0">
                        <TextBlock Text="Entre com o codigo de barras do produto"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBox x:Name="BarcodeTextBox"
                                 Margin="0,10,0,0"
                                 Style="{StaticResource MainBarcodeTextBoxStyle}"
                                 Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="BarcodeTextBox_KeyDown"
                                 GotKeyboardFocus="FocusableElement_GotKeyboardFocus"
                                 BorderBrush="#7DD3FC"
                                 Background="#F8FAFC"
                                 Foreground="#0F172A"
                                 IsTabStop="False"/>
                    </StackPanel>

                    <Button x:Name="AddItemButton"
                            Grid.Column="1"
                            Margin="0,28,12,0"
                            Padding="14,12"
                            Click="AddItem_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            GotKeyboardFocus="FocusableElement_GotKeyboardFocus"
                            IsTabStop="False">
                        <StackPanel>
                            <TextBlock Text="Adicionar item" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AddItemShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SearchProductButton"
                            Grid.Column="2"
                            Margin="0,28,0,0"
                            Padding="14,12"
                            Click="SearchProduct_Click"
                            Background="#0F766E"
                            BorderBrush="#34D399"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            GotKeyboardFocus="FocusableElement_GotKeyboardFocus"
                            IsTabStop="False">
                        <StackPanel>
                            <TextBlock Text="Buscar produto" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SearchProductShortcutLabel, StringFormat=({0})}" FontSize="12" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
