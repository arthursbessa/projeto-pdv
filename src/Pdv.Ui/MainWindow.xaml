<Window x:Class="Pdv.Ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDV Local" Height="760" Width="1240" WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown" Background="#F1F5F9">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.92"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.65"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="16" Margin="0,0,0,14">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#0B1120" Offset="0"/>
                    <GradientStop Color="#111C44" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="22,18">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="PDV" Foreground="White" FontSize="38" FontWeight="Bold" Margin="0,0,14,0"/>
                    <Border Background="#2563EB" CornerRadius="10" Padding="12,6">
                        <TextBlock Text="{Binding OfflineStatus}" Foreground="White" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Itens" Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding ItemCount}" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,0,24,0"/>
                    <TextBlock Text="Total" Foreground="#93C5FD" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="{Binding TotalFormatted}" Foreground="#FDE68A" FontSize="42" FontWeight="Bold"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="500"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Código de barras" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold"/>
                <TextBox x:Name="BarcodeTextBox" Grid.Column="1" Height="38" VerticalContentAlignment="Center" FontSize="17"
                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}" KeyDown="BarcodeTextBox_KeyDown"
                         BorderBrush="#93C5FD" BorderThickness="1.5" Padding="10,0"/>
                <Button Grid.Column="2" Content="Adicionar (ENTER)" Margin="12,0,0,0" Padding="16,8" Click="AddItem_Click"/>
                <Button Grid.Column="3" Content="Produtos" Margin="8,0,0,0" Padding="16,8" Click="OpenProducts_Click" Background="#0F172A" BorderBrush="#0F172A"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="14" Padding="12" Margin="0,0,14,0">
                <DataGrid x:Name="ItemsDataGrid" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem}" AutoGenerateColumns="False"
                          AlternatingRowBackground="#F8FAFC" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          CanUserAddRows="False" CellEditEnding="ItemsDataGrid_CellEditEnding" BorderBrush="#BFDBFE" BorderThickness="1">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#EFF6FF"/>
                            <Setter Property="Foreground" Value="#1E3A8A"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,6"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Barcode}" Width="170" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Descrição" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Qtd" Binding="{Binding Quantity}" Width="80"/>
                        <DataGridTextColumn Header="Preço" Binding="{Binding Price, StringFormat=R$ {0:N2}}" Width="120" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=R$ {0:N2}}" Width="130" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="14" Padding="16">
                <StackPanel>
                    <TextBlock Text="Ações" FontWeight="Bold" FontSize="20" Margin="0,0,0,12"/>
                    <Button Content="Finalizar Venda (F2)" Margin="0,0,0,10" Padding="12" Click="Finalize_Click"/>
                    <Button Content="Remover Item (F4)" Margin="0,0,0,10" Padding="12" Command="{Binding RemoveSelectedCommand}" Background="#334155" BorderBrush="#334155"/>
                    <Button Content="Cancelar Venda (ESC)" Padding="12" Command="{Binding CancelSaleCommand}" Background="#B91C1C" BorderBrush="#B91C1C"/>
                    <Separator Margin="0,16"/>
                    <TextBlock Text="Resumo" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding ItemCount, StringFormat=Itens: {0}}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding TotalFormatted, StringFormat=Total: {0}}" FontSize="26" FontWeight="Bold" Margin="0,8,0,0" Foreground="#1D4ED8"/>
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,16,0,0" Foreground="#334155"/>
                </StackPanel>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Margin="0,12,0,0" Background="#E2E8F0">
            <StatusBarItem>
                <TextBlock Text="ENTER adiciona | F2 finaliza | F4 remove | ESC cancela | CTRL+F foco código"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding DatabaseStatus}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
